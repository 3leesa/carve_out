<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>TECH_SemaineDateDeCreation__c</fullName>
    <description>Sprint 69 - Permet de récupérer le numéro de la semaine correspondant à la date de création, dans le cadre des rapports sur les opportunités commerciales</description>
    <externalId>false</externalId>
    <formula>MOD(FLOOR( (DATEVALUE( CreatedDate ) - DATE(YEAR(DATEVALUE(CreatedDate)), 01, 01))/7),52)+1</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Date de création (semaine)</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
