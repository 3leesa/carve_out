<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>CompteurVueDeListe__c</fullName>
    <description>Pour savoir le nombre de jours que le case à passer dans la vue de liste</description>
    <externalId>false</externalId>
    <formula>IF(ISNULL(dateVueDeListe__c) , 0, NOW()-dateVueDeListe__c)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Présent dans la vue de liste (jours)</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
