<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Statut_Intent__c</fullName>
    <description>CRM-323 : INTENT - Ajout du champ Status dans l&apos;envoi de la demande</description>
    <externalId>false</externalId>
    <formula>IF(ISPICKVAL(Status, &apos;Terminé&apos;), &apos;closed_solved&apos;,
IF(CONTAINS(Text(Status), &apos;Annulé&apos;), &apos;closed_dismissed&apos;, &apos;received&apos;))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Statut Intent</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
