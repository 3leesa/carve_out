<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>INT_VR007_AnnuleesSansMotif</fullName>
    <active>true</active>
    <description>Ne plus acecpter les interventions qui ont le statut annulé et qui n’ont pas de motif d’annulation</description>
    <errorConditionFormula>AND(NOT($Setup.CS001_NeutraliserRegles__c.TECH_NeutraliserRegleValidation__c),
ISCHANGED(Status), 
OR(ISBLANK(TEXT(MotifAnnulation__c)), ISNULL(TEXT(MotifAnnulation__c))),
OR(ISPICKVAL(Status, &apos;108&apos;), ISPICKVAL(Status, &apos;101&apos;)))</errorConditionFormula>
    <errorDisplayField>MotifAnnulation__c</errorDisplayField>
    <errorMessage>Veuillez remplir le champ &quot;Motif Annulation&quot;</errorMessage>
</ValidationRule>
